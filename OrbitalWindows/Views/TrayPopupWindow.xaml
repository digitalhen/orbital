<Window x:Class="Orbital.Views.TrayPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orbital"
        Width="340" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated">
    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="1" CornerRadius="8"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>
        <StackPanel x:Name="RootPanel" Margin="0">

            <!-- Update Banner -->
            <Border x:Name="UpdateBanner" Background="#FFF3CD" CornerRadius="4"
                    Margin="10,8,10,0" Padding="10,6" Visibility="Collapsed" Cursor="Hand"
                    MouseLeftButtonUp="UpdateBanner_Click">
                <TextBlock x:Name="UpdateBannerText" FontSize="12" TextWrapping="Wrap"
                           Foreground="#856404" Text="A new version of Orbital is available. Click to update."/>
            </Border>

            <!-- Header -->
            <Grid Margin="14,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="MissionNameText" FontSize="13" FontWeight="Bold"/>
                    <TextBlock x:Name="MissionSubtitleText" FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Ellipse x:Name="LiveIndicator" Width="6" Height="6" Margin="0,2,4,0"/>
                    <TextBlock x:Name="LiveText" FontSize="10" FontWeight="SemiBold"
                               FontFamily="Consolas"/>
                </StackPanel>
            </Grid>

            <Separator/>

            <!-- Phase -->
            <StackPanel x:Name="PhasePanel" Orientation="Horizontal" Margin="14,8,14,8">
                <TextBlock x:Name="PhaseIcon" FontSize="16" VerticalAlignment="Top"
                           Foreground="#0078D7" Width="24"/>
                <StackPanel Margin="4,0,0,0">
                    <TextBlock x:Name="PhaseName" FontSize="13" FontWeight="Medium"/>
                    <TextBlock x:Name="PhaseDescription" FontSize="11"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                </StackPanel>
            </StackPanel>

            <Separator/>

            <!-- Metrics -->
            <StackPanel x:Name="MetricsPanel" Margin="14,8,14,8"/>

            <Separator/>

            <!-- Crew -->
            <StackPanel x:Name="CrewPanel" Margin="14,8,14,8">
                <TextBlock Text="Crew" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,4"/>
            </StackPanel>

            <Separator/>

            <!-- Settings -->
            <StackPanel x:Name="SettingsPanel" Margin="14,8,14,8">
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Units" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                               VerticalAlignment="Center"/>
                    <ComboBox x:Name="UnitsCombo" Grid.Column="2" Width="170" FontSize="12"
                              SelectionChanged="UnitsCombo_SelectionChanged"/>
                </Grid>

                <CheckBox x:Name="FloatingWidgetCheck" Content="Floating Widget" FontSize="13"
                          Margin="0,4,0,4" Click="FloatingWidget_Click"/>

                <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at Login" FontSize="13"
                          Margin="0,4,0,8" Click="LaunchAtLogin_Click"/>

                <TextBlock Text="Show in System Tray" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           Margin="0,0,0,4"/>
                <StackPanel x:Name="MetricTogglesPanel"/>
            </StackPanel>

            <Separator/>

            <!-- Footer -->
            <Grid Margin="14,8,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterText" Grid.Column="0" FontSize="11"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           VerticalAlignment="Center"/>
                <Button x:Name="TipButton" Grid.Column="1" Content="&#x2615; Tip"
                        FontSize="11" Margin="8,0,0,0" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                        Click="TipButton_Click"/>
                <Button x:Name="QuitButton" Grid.Column="2" Content="Quit"
                        FontSize="13" Margin="8,0,0,0" Background="Transparent"
                        BorderThickness="0" Cursor="Hand"
                        Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                        Click="QuitButton_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
